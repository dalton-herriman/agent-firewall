AGENT_FIREWALL_APP_ENV=development
AGENT_FIREWALL_APP_NAME=agent-firewall
AGENT_FIREWALL_APP_VERSION=0.1.0
AGENT_FIREWALL_API_PREFIX=/v1
AGENT_FIREWALL_DATABASE_URL=postgresql+asyncpg://agent_firewall:agent_firewall@localhost:5432/agent_firewall
AGENT_FIREWALL_REDIS_URL=redis://localhost:6379/0
AGENT_FIREWALL_OTEL_SERVICE_NAME=agent-firewall
AGENT_FIREWALL_OTEL_EXPORTER_OTLP_ENDPOINT=
AGENT_FIREWALL_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_FIREWALL_RATE_LIMIT_MAX_REQUESTS=30
AGENT_FIREWALL_DEFAULT_POLICY_MODE=deny
AGENT_FIREWALL_SERVER_BROKER_ENABLED=true
AGENT_FIREWALL_AUTH_ENABLED=false
AGENT_FIREWALL_API_KEYS=[]
